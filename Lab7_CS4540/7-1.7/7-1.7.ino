void setup() {
  if (!display.begin(SSD1306_SWITCHCAPVCC, OLED_ADDRESS)) {
    while (1);
  }

  display.clearDisplay();

  display.drawBitmap(
    0,
    0,
    heart_logo,
    LOGO_WIDTH,
    LOGO_HEIGHT,
    WHITE
  );

  display.display();
}

void loop() {
  // Optional animation
  display.invertDisplay(true);
  delay(1200);
  display.invertDisplay(false);
  delay(1200);
}
